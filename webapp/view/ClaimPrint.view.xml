<mvc:View
    controllerName="isuzu.com.zclaimenquiry.controller.ClaimPrint"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:table="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    xmlns:l="sap.ui.layout"
    xmlns:rowmodes="sap.ui.table.rowmodes"
    xmlns:layout="sap.ui.layout"
    xmlns:fb="sap.ui.comp.filterbar"
    height="100%"
>

<Page
    id="page1"
    title=""
    showNavButton="true"
    navButtonPress="onNavBack"
>
    <headerContent>
        <Button
            id="btnPrint"
            icon="sap-icon://print"
            text="Print"
            press="onPrintPress"
            type="Emphasized"
            class="noPrint"
        />
    </headerContent>

    <content>
        <VBox
            id="_IDGenVBox"
            alignItems="Center"
            justifyContent="Center"
            width="40%"
            class="claimPrintContainer"
        >
        <HBox id="printDateTimeContainer" class="printDateTime" justifyContent="End" width="100%">
            <Text id="printDateTimeText" text="{path:'', formatter:'.formatCurrentDateTime'}" />
        </HBox>
            <!-- Header -->
            <HBox id="_IDGenHBox1"
                class="claimHeader"
                alignItems="Center"
                justifyContent="Center"
            >
                <Text id="_IDGenText13" text="CLAIM ENQUIRY DETAILS" class="claimHeaderText" />
            </HBox>

            <!-- Table -->
            <table:Table
                id="claimTable"
                selectionMode="None"
                width="40%"
                rows="{path:'claimEnquiryPrint>/report'}"
                class="claimTable"
                columnHeaderVisible="false"
            >
                <table:columns>
                    <table:Column id="_IDGenColumn16">
                        <table:template>
                            <Text id="_IDGenText14" text="{claimEnquiryPrint>FieldName}" class="claimLabel" wrapping="true" />
                        </table:template>
                    </table:Column>
                    <table:Column id="_IDGenColumn17">
                        <table:template>
                            <Text id="_IDGenText15" text="{claimEnquiryPrint>FieldValue}" class="claimValue" wrapping="true" />
                        </table:template>
                    </table:Column>
                </table:columns>
            </table:Table>
        </VBox>
    </content>
</Page>

</mvc:View>
