<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:u="sap.ui.unified"
    xmlns:table="sap.ui.table"
>
    <Dialog
        id="_IDGenDialog1"
        title="{i18n>ClaimEnquiryDetails}"
        class="sapUiResponsivePadding"
        draggable="true"
        resizable="true"
    >
        <content>
            <table:Table
                id="_IDGenTable"
                selectionMode="None"
                width="auto"
                rows="{path:'claimEnquiryPrint>/report'}"
                rowActionCount="auto"
                ariaLabelledBy="title"
            >
                <table:columns>
                    <table:Column id="_IDGenColumn">
                        <table:template>
                            <Text
                                id="_IDGenText"
                                width="140px"
                                text="{claimEnquiryPrint>FieldName}"
                                wrapping="true"
                            />
                        </table:template>
                    </table:Column>
                    <table:Column id="_IDGenColumn15">
                        <table:template>
                            <Text
                                id="_IDGenText12"
                                width="140px"
                                text="{claimEnquiryPrint>FieldValue}"
                                wrapping="true"
                            />
                        </table:template>
                    </table:Column>
                </table:columns>
            </table:Table>
        </content>
        <endButton>
            <Button
                id="_IDGenButton2"
                text="{i18n>Cancel}"
                press="onPrintCancelPress"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
