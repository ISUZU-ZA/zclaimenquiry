<mvc:View
    controllerName="isuzu.com.zclaimenquiry.controller.main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:table="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    xmlns:l="sap.ui.layout"
    xmlns:layout="sap.ui.layout"
    xmlns:fb="sap.ui.comp.filterbar"
    height="100%"
>
    <Page
        id="page"
        
    >
        <content>
            <VBox id="_IDGenVBox1">
                <fb:FilterBar
                    id="_IDGenFilterBar"
                    persistencyKey="myPersKey"
                    useToolbar="false"
                    search=".onSearch"
                    filterChange=".onFilterChange"
                    afterVariantLoad=".onAfterVariantLoad"
                >
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem
                            id="_IDGenFilterGroupItem2"
                            name="Zclaimdte"
                            label="{i18n>Zclaimdte}"
                            groupName="Group1"
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <DateRangeSelection
                                    id="_IDGenDateRangeSelection1"
                                    change=".onSelectionChange"
                                    showFooter="false"
                                    width="40px"
                                    value=""
                                />
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem
                            id="_IDGenFilterGroupItem3"
                            name="ZinvnoFrom"
                            label="{i18n>ZinvnoFrom}"
                            groupName="Group2"
                            visibleInFilterBar="true"
                            mandatory="false"
                        >
                            <fb:control>
                                <Input
                                    id="_IDInputZinvnoFrom"
                                    showSuggestion="true"
                                    width="30px"
                                />
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem
                            id="_IDGenFilterGroupItem32"
                            name="ZinvnoTo"
                            label="{i18n>ZinvnoTo}"
                            groupName="Group2"
                            visibleInFilterBar="true"
                            mandatory="false"
                        >
                            <fb:control>
                                <Input
                                    id="_IDInputZinvnoTo"
                                    showSuggestion="true"
                                    width="30px"
                                />
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem
                            id="_IDGenFilterGroupItem4"
                            name="ZmatnrFrom"
                            label="{i18n>ZmatnrFrom}"
                            groupName="Group3"
                            visibleInFilterBar="true"
                            mandatory="false"
                        >
                            <fb:control>
                                <Input
                                    id="_IDInputZmatnr"
                                    showSuggestion="true"
                                    width="30px"
                                />
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem
                            id="_IDGenFilterGroupItem42"
                            name="ZmatnrTo"
                            label="{i18n>ZmatnrTo}"
                            groupName="Group3"
                            visibleInFilterBar="true"
                            mandatory="false"
                        >
                            <fb:control>
                                <Input
                                    id="_IDInputZmatnrTo"
                                    showSuggestion="true"
                                    width="30px"
                                />
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem
                            id="_IDGenFilterGroupItem5"
                            name="ZclaimFrom"
                            label="{i18n>ZclaimFrom}"
                            groupName="Group4"
                            visibleInFilterBar="true"
                            mandatory="false"
                        >
                            <fb:control>
                                <Input
                                    id="_IDInputZclaim"
                                    showSuggestion="true"
                                    width="30px"
                                />
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem
                            id="_IDGenFilterGroupItem52"
                            name="ZclaimTo"
                            label="{i18n>ZclaimTo}"
                            groupName="Group4"
                            visibleInFilterBar="true"
                            mandatory="false"
                        >
                            <fb:control>
                                <Input
                                    id="_IDInputZclaimTo"
                                    showSuggestion="true"
                                    width="30px"
                                />
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem
                            id="_IDGenFilterGroupItem7"
                            name="Zstatus"
                            label="{i18n>Zstatus}"
                            groupName="Group5"
                            visibleInFilterBar="true"
                            mandatory="false"
                        >
                            <fb:control>
                                <ComboBox
                                    id="_IDGenComboBox1"
                                    selectedKey ="L"
                                    items="{
					path: '/f4ClaimStatusSet',
					sorter: { path: 'Zstatus' }
				}"
                                >
                                    <core:Item
                                        id="_IDGenItem1"
                                        key="{Zstatus}"
                                        text="{text}"
                                    />
                                </ComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem
                            id="_IDGenFilterGroupItem6"
                            name="Showclaimdoc"
                            label="{i18n>Showclaimdoc}"
                            groupName="Group6"
                            visibleInFilterBar="true"
                            mandatory="false"
                        >
                            <fb:control>
                                <CheckBox
                                    id="_IDGenCheckBox"
                                    selected="false"
                                />
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>
                <VBox
                    id="_IDGenVBox3"
                    class="stickyHeader"
                >
                    <HBox
                        id="headerBar"
                        justifyContent="SpaceBetween"
                        alignItems="Center"
                    >
                        <Title
                            id="tableTitle"
                            text="{i18n>Items}"
                            class="sapUiSmallMarginBegin"
                        />
                        <HBox id="_IDGenHBox3">
                            <SearchField
                                id="_IDGenSearchField1"
                                placeholder="Search"
                                liveChange="FilterSearch"
                                width="15rem"
                                class="sapUiSmallMarginEnd"
                            />
                            <Button
                                id="_IDGenButton4"
                                icon="sap-icon://excel-attachment"
                                press="onExport"
                                class="sapUiSmallMarginEnd"
                            />
                        </HBox>
                    </HBox>
                </VBox>
            </VBox>
          
               <Table
                    id="_IDGenTable1"
                    alternateRowColors="true"
                    width="auto"
                    class="sapUiSmallMarginTop sapUiSmallMarginBegin sapUiSmallMarginEnd"
                    items="{path:'claimEnquiry>/report'}"
                    growing="true"
                    growingThreshold="10"
                >
                    <columns>

                        <Column id="_IDGenColumn1">
                            <Label id="_IDGenLabel" text="{i18n>Zclaim}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn2">
                            <Label id="_IDGenLabel1" text="{i18n>Zclaimdte}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn3">
                            <Label id="_IDGenLabel2" text="{i18n>Ztype}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn4">
                            <Label id="_IDGenLabel3" text="{i18n>Zstatus}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn5">
                            <Label id="_IDGenLabel4" text="{i18n>Docoutstand}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn6">
                            <Label id="_IDGenLabel5" text="{i18n>Partn}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn7">
                            <Label id="_IDGenLabel6" text="{i18n>Zmatdesc}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn8">
                            <Label id="_IDGenLabel7" text="{i18n>Dgcl}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn9">
                            <Label id="_IDGenLabel8" text="{i18n>Profl}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn10">
                            <Label id="_IDGenLabel9" text="{i18n>Zqty}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn11">
                            <Label id="_IDGenLabel10" text="{i18n>Zinvno}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn12">
                            <Label id="_IDGenLabel11" text="{i18n>Zcrednote}" width="6rem" wrapping="true"/>
                        </Column>

                        <Column id="_IDGenColumn13">
                            <Label id="_IDGenLabel12" text="{i18n>Upload}" width="6rem" wrapping="true"/>
                        </Column>

                    </columns>

                    <items>
                        <ColumnListItem id="_IDGenColumnListItem">
                            <cells>

                                <Button
                                    id="_IDGenButton"
                                    icon="sap-icon://print"
                                    text="{claimEnquiry>Zclaim}"
                                    press="onPrint"
                                />

                                <Text
                                    id="_IDGenText1"
                                    text="{
                                        path: 'claimEnquiry>Zclaimdte',
                                        type: 'sap.ui.model.type.Date',
                                        formatOptions: { pattern: 'dd.MM.yyyy', UTC: true }
                                    }"
                                />

                                <Text id="_IDGenText2" text="{claimEnquiry>Ztype}" />
                                <Text id="_IDGenText3" text="{claimEnquiry>Zstatustext}" />
                                <Text id="_IDGenText4" text="{claimEnquiry>Docoutstand}" />
                                <Text id="_IDGenText5" text="{claimEnquiry>Zmatnr}" />
                                <Text id="_IDGenText6" text="{claimEnquiry>Zmatdesc}" width="7rem"/>
                                <Text id="_IDGenText7" text="{claimEnquiry>Dgcl}" />
                                <Text id="_IDGenText8" text="{claimEnquiry>Profl}" />
                                <Text id="_IDGenText9" text="{claimEnquiry>Zqty}" />
                                <Text id="_IDGenText10" text="{claimEnquiry>Zinvno}" />
                                <Text id="_IDGenText11" text="{claimEnquiry>Zcrednote}" />

                                <Button
                                    id="_IDGenButton1"
                                    icon="sap-icon://upload"
                                    press="onUpload"
                                />

                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>          
        </content>
    </Page>
</mvc:View>
